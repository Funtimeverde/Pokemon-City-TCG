{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/remix"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/" }
  ],
  "analytics": {
    "scriptSrc": "/_vercel/analytics/script.js",
    "eventEndpoint": "/_vercel/analytics/event",
    "viewEndpoint": "/_vercel/analytics/view"
  }
}
